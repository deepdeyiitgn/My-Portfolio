# ─────────────────────────────────────────────────────────────────────────────
# Environment variables for Deep Dey Portfolio
# Copy this file to .env.local for local development — NEVER commit .env.local
# All production values are stored as Vercel Environment Variables.
# ─────────────────────────────────────────────────────────────────────────────

# MONGODB_URI
# MongoDB Atlas connection string used by the Journal and Category API routes.
# Format: mongodb+srv://<user>:<pass>@cluster0.mongodb.net/<dbname>?retryWrites=true&w=majority
# Required for: /api/journal.js, /api/categories.js
MONGODB_URI="mongodb+srv://user:password@cluster.mongodb.net/portfolio"

# SPACE_PASSWORD
# Upload credential for the static.qlynk.me CDN proxy (/api/upload-image.js).
# This is sent as an Authorization Bearer token to the upstream CDN REST API.
# It is ALSO used to gate the /dashboard admin page via cookie-based session auth.
# Required for: /api/upload-image.js, /api/auth.js
SPACE_PASSWORD="your-cdn-upload-password-here"

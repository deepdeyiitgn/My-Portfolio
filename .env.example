# ─────────────────────────────────────────────────────────────────────────────
# Environment variables for Deep Dey Portfolio
# Copy this file to .env.local for local development — NEVER commit .env.local
# All production values are stored as Vercel Environment Variables.
# ─────────────────────────────────────────────────────────────────────────────

# MONGODB_URI
# MongoDB Atlas connection string used by the Journal and Category API routes.
# Format: mongodb+srv://<user>:<pass>@cluster0.mongodb.net/<dbname>?retryWrites=true&w=majority
# Required for: /api/journal.js, /api/categories.js
MONGODB_URI="mongodb+srv://user:password@cluster.mongodb.net/portfolio"

# SPACE_PASSWORD
# Upload credential for the static.qlynk.me CDN proxy (/api/upload-image.js).
# This is sent as an Authorization Bearer token to the upstream CDN REST API.
# It is ALSO used to gate the /dashboard admin page via cookie-based session auth.
# Required for: /api/upload-image.js, /api/auth.js
SPACE_PASSWORD="your-cdn-upload-password-here"

# VITE_GOOGLE_CLIENT_ID
# Google OAuth 2.0 Client ID for the comment section's "Sign in with Google" feature.
# Create one at: https://console.cloud.google.com/ → APIs & Services → Credentials
# Authorized JavaScript origins must include your deployment domain (e.g., https://deepdey.vercel.app)
# This value is exposed to the browser (VITE_ prefix).
# Required for: /src/main.tsx (GoogleOAuthProvider), /src/components/CommentSection.tsx
VITE_GOOGLE_CLIENT_ID="your-google-oauth-client-id.apps.googleusercontent.com"

# GOOGLE_CLIENT_ID
# Same Google OAuth Client ID — used on the server side to verify Google ID tokens.
# The backend calls Google's tokeninfo API and validates that the token's `aud` matches
# this value to prevent token injection from other Google OAuth apps.
# Required for: /api/journal.js (verifyGoogleToken)
GOOGLE_CLIENT_ID="your-google-oauth-client-id.apps.googleusercontent.com"

# KLIPY_API
# Server-side API key for Klipy media search used in the journal comment composer.
# Keep this secret only on the backend (do not expose in VITE_* env vars).
# Required for: /api/journal.js?action=klipy-search
KLIPY_API="your-klipy-api-key"

# YOUTUBE_API_KEY (or GOOGLE_API_KEY)
# Optional key for /api/live.js to fetch richer YouTube stats and top comments.
# Create one at: https://console.cloud.google.com/ → APIs & Services → Credentials
# Also enable "YouTube Data API v3" in APIs & Services → Library.
# Use EXACT format below (replace only the value part):
YOUTUBE_API_KEY="AIzaSy-your-youtube-data-api-v3-key"
# Alternative alias supported by this repo:
# GOOGLE_API_KEY="AIzaSy-your-youtube-data-api-v3-key"
